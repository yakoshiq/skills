---
import { Code } from 'astro:components';

interface Props {
  name: string;
  desc: string;
  note: string;
  before: string;
  after: string;
  lang?: 'ts' | 'diff';
}

const { name, desc, note, before, after, lang = 'ts' } = Astro.props;
const repo = 'https://github.com/yakoshiq/skills';
const themes = { light: 'rose-pine-dawn', dark: 'rose-pine' };
const codeClass =
  'ide block overflow-x-auto bg-card px-5 py-4 text-[11.5px] leading-[1.7] dark:bg-night-card';
---

<section id={name} class="reveal-io mt-14 scroll-mt-8">
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="text-[15px] font-semibold">
      <a
        href={`${repo}/blob/main/skills/${name}/SKILL.md`}
        class="text-ink no-underline hover:text-rose dark:text-snow dark:hover:text-bloom"
      >
        {name}
      </a>
    </h3>
    <a
      href={`${repo}/blob/main/docs/examples/${name}.md`}
      class="shrink-0 text-[12px] text-faint no-underline hover:text-rose dark:text-dim dark:hover:text-bloom"
    >
      full before / after
    </a>
  </div>
  <p class="mt-2 max-w-[68ch] text-[13px] leading-relaxed text-faint dark:text-dim">{desc}</p>
  <div class="mt-5 grid overflow-hidden rounded-lg border border-line md:grid-cols-2 dark:border-seam">
    <div class="min-w-0">
      <p class="border-b border-line bg-bad-bg px-4 py-2 text-[11px] font-medium tracking-wide text-bad dark:border-seam dark:bg-dbad-bg dark:text-dbad">
        before
      </p>
      <Code code={before} lang={lang} themes={themes} class={codeClass} />
    </div>
    <div class="min-w-0 border-t border-line md:border-t-0 md:border-l dark:border-seam">
      <p class="border-b border-line bg-good-bg px-4 py-2 text-[11px] font-medium tracking-wide text-good dark:border-seam dark:bg-dgood-bg dark:text-dgood">
        after
      </p>
      <Code code={after} lang={lang} themes={themes} class={codeClass} />
    </div>
  </div>
  <p class="mt-3 text-[12.5px] leading-[1.55] text-faint dark:text-dim">
    {note}
  </p>
</section>
